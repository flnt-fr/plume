---
import Card from '@/components/Card.astro';
import { ui } from '@/i18n';
import type { ProjectCardProps } from './ProjectCard';

type Props = ProjectCardProps;
const { id, title, date, stack, links, hasBody } = Astro.props;
---

<Card {id}>
  <div class="flex flex-col gap-2">
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
      <h2 class="font-semibold">{title}</h2>
      <time class="text-xs text-base-content/65 shrink-0">{date}</time>
    </div>
    {stack.length > 0 && (
      <ul class="flex flex-wrap gap-2" aria-label={ui.projects.stackAriaLabel}>
        {stack.map((tech) => (
          <li class="badge badge-ghost badge-sm">{tech}</li>
        ))}
      </ul>
    )}
    {hasBody && (
      <div class="prose prose-sm max-w-none mt-1">
        <slot />
      </div>
    )}
    {links && links.length > 0 && (
      <ul class="flex flex-wrap gap-4 mt-1">
        {links.map(({ label, url }) => (
          <li>
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-base-content/70 hover:text-base-content transition-colors"
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Card>
