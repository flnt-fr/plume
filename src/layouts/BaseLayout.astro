---
import '../styles/global.css';
import DemoBanner from '@/components/DemoBanner.astro';
import Footer from '@/components/Footer.astro';
import { defaultOgImage, IS_DEMO, siteName, siteUrl } from '@/config';
import { ui } from '@/i18n';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  appendSiteName?: boolean;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  appendSiteName = true,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = new URL(defaultOgImage, siteUrl).toString();
const pageTitle = appendSiteName ? `${title} — ${siteName}` : title;

const navLinks = [
  { href: '/about', label: ui.nav.about },
  { href: '/experiences', label: ui.nav.experiences },
  { href: '/projects', label: ui.nav.projects },
  { href: '/watch', label: ui.nav.watch },
  { href: '/now', label: ui.nav.now },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteName} — ${ui.rss.feedTitle}`}
      href={`${siteUrl}/watch/rss.xml`}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="bg-base-100 text-base-content min-h-screen">
    {IS_DEMO && <DemoBanner />}
    <header class="border-b border-base-300">
      <div class="max-w-2xl mx-auto px-6 py-4 flex items-baseline gap-8">
        <a href="/" class="font-mono text-sm font-semibold shrink-0">{siteName}</a>
        <nav aria-label={ui.nav.ariaLabel}>
          <ul class="flex flex-wrap gap-x-6 gap-y-2">
            {
              navLinks.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    class="text-sm hover:text-base-content/70 transition-colors"
                    aria-current={Astro.url.pathname === href ? 'page' : undefined}
                  >
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
