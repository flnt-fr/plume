---
import { getCollection, render } from 'astro:content';
import Pagination from '@/components/Pagination.astro';
import WatchCard from '@/components/watch/WatchCard.astro';
import { VEILLE_PAGE_SIZE } from '@/config';
import { ui } from '@/i18n';
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = ui.watch.title;
const description = 'Commented links on software development and artificial intelligence.';

const allEntries = await getCollection('watch');
const sorted = allEntries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(sorted.length / VEILLE_PAGE_SIZE);

const entriesWithContent = await Promise.all(
  sorted.slice(0, VEILLE_PAGE_SIZE).map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  }),
);
---

<BaseLayout {title} {description} canonicalPath="/watch">
  <div class="max-w-2xl mx-auto px-6 py-16">
    <div class="flex items-baseline justify-between mb-8">
      <h1 class="text-4xl font-bold">{ui.watch.title}</h1>
      <a
        href="/watch/rss.xml"
        class="text-sm text-base-content/70 hover:text-base-content transition-colors"
      >
        {ui.watch.rssLink}
      </a>
    </div>

    <ol class="flex flex-col gap-4">
      {
        entriesWithContent.map(({ entry, Content }) => (
          <li>
            <WatchCard
              title={entry.data.title}
              url={entry.data.url}
              date={entry.data.date}
              sourceName={entry.data.source.name}
              sourceUrl={entry.data.source.url}
              tags={entry.data.tags}
              hasComment={!!entry.body?.trim()}
            >
              <Content />
            </WatchCard>
          </li>
        ))
      }
    </ol>

    {totalPages > 1 && <Pagination currentPage={1} {totalPages} basePath="/watch" />}
  </div>
</BaseLayout>
