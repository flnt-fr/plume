{
  "name": "plume",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "test": "playwright test",
    "lighthouse": "astro build && (npm run preview -- --port 4322 & sleep 2 && npx unlighthouse --site http://localhost:4322)",
    "build:sizes": "astro build 2>&1 | grep '→'"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.1",
    "astro-compress": "^2.4.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "typescript": "^5.9.3"
  }
}
