---
import '../styles/global.css';
import DemoBanner from '@/components/DemoBanner.astro';
import Footer from '@/components/Footer.astro';
import Nav from '@/components/Nav.astro';
import { defaultOgImage, IS_DEMO, siteName, siteUrl } from '@/config';
import { ui } from '@/i18n';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  appendSiteName?: boolean;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  appendSiteName = true,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = new URL(defaultOgImage, siteUrl).toString();
const pageTitle = appendSiteName ? `${title} — ${siteName}` : title;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteName} — ${ui.rss.feedTitle}`}
      href={`${siteUrl}/watch/rss.xml`}
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body class="bg-base-100 text-base-content min-h-screen">
    {IS_DEMO && <DemoBanner />}
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
